---
import AlertHost from '../components/alerts/AlertHost.jsx';
import { isRegistrationOpen } from '../lib/registration';

interface Props {
  title: string;
}

const { title } = Astro.props;
const user = Astro.locals.user;

let registrationOpen = true;
try {
  registrationOpen = (await isRegistrationOpen()).open;
} catch {
  registrationOpen = false;
}
---

<!DOCTYPE html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0B0F19" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | AI Audio Transcriber</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#0B0F19] text-gray-100 font-['Outfit',sans-serif] min-h-full flex flex-col selection:bg-primary selection:text-white overflow-x-hidden">
    <header class="border-b border-[#1F293D] bg-[#0E1524]/90 backdrop-blur-md sticky top-0 z-50 pt-[env(safe-area-inset-top)]">
      <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 h-14 sm:h-16 flex items-center justify-between gap-2">
        <a href="/" class="flex items-center gap-2 group min-w-0 shrink">
          <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-gradient-to-tr from-primary to-accent flex items-center justify-center shadow-lg shadow-primary/20 group-hover:scale-105 transition-transform shrink-0">
            <svg class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <span class="text-lg sm:text-xl font-bold bg-gradient-to-r from-white via-gray-200 to-gray-400 bg-clip-text text-transparent truncate">
            Transcribir<span class="text-primary font-extrabold">.AI</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-3 lg:gap-4">
          {user ? (
            <>
              <a href="/dashboard" class="text-sm text-gray-300 hover:text-white transition-colors whitespace-nowrap">Mi Panel</a>
              {user.role === 'ADMIN' && (
                <>
                  <a href="/admin" class="text-sm text-accent-light hover:text-accent transition-colors font-medium border border-accent/30 rounded-lg px-2.5 py-1 bg-accent/5 whitespace-nowrap">API Keys</a>
                  <a href="/admin/users" class="text-sm text-accent-light hover:text-accent transition-colors font-medium border border-accent/30 rounded-lg px-2.5 py-1 bg-accent/5 whitespace-nowrap">Usuarios</a>
                </>
              )}
              <div class="h-4 w-[1px] bg-[#1F293D]"></div>
              <span class="text-xs text-gray-400 font-mono hidden lg:inline max-w-[180px] truncate">{user.email}</span>
              <button id="logoutBtn" class="text-sm bg-red-950/40 text-red-400 border border-red-900/30 hover:bg-red-900/40 px-3 py-1.5 rounded-lg transition-all whitespace-nowrap">
                Cerrar Sesión
              </button>
            </>
          ) : (
            <>
              <a href="/login" class="text-sm text-gray-300 hover:text-white transition-colors whitespace-nowrap">Iniciar Sesión</a>
              {registrationOpen && (
                <a href="/register" class="text-sm bg-gradient-to-r from-primary to-primary-dark hover:from-primary-dark hover:to-primary text-white font-medium px-4 py-2 rounded-xl transition-all shadow-md shadow-primary/10 hover:shadow-primary/20 whitespace-nowrap">
                  Registrarse
                </a>
              )}
            </>
          )}
        </nav>

        <!-- Mobile menu button -->
        <button
          id="mobileMenuBtn"
          type="button"
          class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-xl border border-[#1F293D] bg-[#151D30]/60 text-gray-300 hover:text-white hover:bg-[#1E2942] transition-all"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobileNav"
        >
          <svg id="menuIconOpen" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menuIconClose" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Mobile dropdown -->
      <nav
        id="mobileNav"
        class="md:hidden hidden border-t border-[#1F293D] bg-[#0E1524] px-3 pb-4 pt-2 space-y-1"
      >
        {user ? (
          <>
            <p class="px-3 py-2 text-[11px] text-gray-500 font-mono truncate">{user.email}</p>
            <a href="/dashboard" class="block px-3 py-3 rounded-xl text-sm text-gray-200 hover:bg-[#151D30] transition-colors">Mi Panel</a>
            {user.role === 'ADMIN' && (
              <>
                <a href="/admin" class="block px-3 py-3 rounded-xl text-sm text-accent-light hover:bg-accent/10 transition-colors">API Keys / Proveedores</a>
                <a href="/admin/users" class="block px-3 py-3 rounded-xl text-sm text-accent-light hover:bg-accent/10 transition-colors">Usuarios</a>
              </>
            )}
            <button id="logoutBtnMobile" class="w-full text-left px-3 py-3 rounded-xl text-sm text-red-400 hover:bg-red-950/30 transition-colors">
              Cerrar Sesión
            </button>
          </>
        ) : (
          <>
            <a href="/login" class="block px-3 py-3 rounded-xl text-sm text-gray-200 hover:bg-[#151D30] transition-colors">Iniciar Sesión</a>
            {registrationOpen && (
              <a href="/register" class="block px-3 py-3 rounded-xl text-sm font-semibold text-white bg-primary/20 border border-primary/30 hover:bg-primary/30 transition-colors text-center">Registrarse</a>
            )}
          </>
        )}
      </nav>
    </header>

    <main class="flex-grow flex flex-col min-w-0">
      <slot />
    </main>

    <footer class="border-t border-[#1F293D] bg-[#080B13] py-5 sm:py-6 px-4 text-center text-xs sm:text-sm text-gray-500 pb-[max(1.25rem,env(safe-area-inset-bottom))]">
      <p>&copy; 2026 Transcribir.AI. Todos los derechos reservados.</p>
    </footer>

    <AlertHost client:load />

    <script>
      const menuBtn = document.getElementById('mobileMenuBtn');
      const mobileNav = document.getElementById('mobileNav');
      const iconOpen = document.getElementById('menuIconOpen');
      const iconClose = document.getElementById('menuIconClose');

      function setMenuOpen(open) {
        if (!mobileNav || !menuBtn) return;
        mobileNav.classList.toggle('hidden', !open);
        iconOpen?.classList.toggle('hidden', open);
        iconClose?.classList.toggle('hidden', !open);
        menuBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      }

      menuBtn?.addEventListener('click', () => {
        const open = mobileNav?.classList.contains('hidden');
        setMenuOpen(!!open);
      });

      async function doLogout() {
        const ok = window.alerts
          ? await window.alerts.confirm({
              title: 'Cerrar sesión',
              message: '¿Seguro que quieres salir de tu cuenta?',
              confirmLabel: 'Salir',
              cancelLabel: 'Cancelar',
              variant: 'warning',
            })
          : confirm('¿Cerrar sesión?');
        if (!ok) return;

        const response = await fetch('/api/auth/logout', { method: 'POST' });
        if (response.ok) {
          window.location.href = '/login';
        } else if (window.alerts) {
          window.alerts.toast.error('Error al cerrar sesión');
        } else {
          alert('Error al cerrar sesión');
        }
      }

      document.getElementById('logoutBtn')?.addEventListener('click', doLogout);
      document.getElementById('logoutBtnMobile')?.addEventListener('click', doLogout);
    </script>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  html, body {
    background-color: #0B0F19;
    color: #F3F4F6;
  }

  /* Evita zoom automático en iOS al enfocar inputs */
  @media (max-width: 767px) {
    input, select, textarea, button {
      font-size: 16px;
    }
  }

  /* Scroll suave en paneles táctiles */
  .touch-scroll {
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }

  /* Reproductor de audio en tema oscuro */
  audio {
    width: 100%;
    max-width: 100%;
    border-radius: 0.75rem;
    outline: none;
  }

  @keyframes alertSlideIn {
    from { opacity: 0; transform: translateY(-12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (min-width: 640px) {
    @keyframes alertSlideIn {
      from { opacity: 0; transform: translateX(16px); }
      to { opacity: 1; transform: translateX(0); }
    }
  }

  @keyframes alertFadeScale {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }
</style>
