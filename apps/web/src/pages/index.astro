---
import Layout from '../layouts/Layout.astro';
const user = Astro.locals.user;
---

<Layout title="Transcribe y Traduce con IA">
  <div class="relative overflow-hidden flex-grow flex items-center justify-center py-20 px-4">
    <!-- Background glow gradients -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] bg-primary/20 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[350px] h-[350px] bg-accent/15 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="max-w-4xl mx-auto text-center z-10 relative">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-primary/20 bg-primary/5 text-primary-light text-sm font-medium mb-6">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
        </span>
        Transcribe Gratis con Capas Gratuitas de IA
      </div>

      <h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-white mb-6 leading-tight">
        Convierte tu Voz en Texto y Traduce <br/>
        <span class="bg-gradient-to-r from-primary via-accent-light to-accent bg-clip-text text-transparent">
          en Segundos usando IA
        </span>
      </h1>

      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Graba en vivo desde tu navegador o sube tus archivos de audio. Transcribe con Google Gemini o Whisper NIM y traduce al instante a cualquier idioma de forma 100% gratuita.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        {user ? (
          <a
            href="/dashboard"
            class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-primary to-primary-dark hover:from-primary-dark hover:to-primary text-white font-semibold rounded-2xl shadow-lg shadow-primary/20 hover:shadow-primary/30 transition-all text-center"
          >
            Ir a Mi Panel de Control
          </a>
        ) : (
          <>
            <a
              href="/register"
              class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-primary to-primary-dark hover:from-primary-dark hover:to-primary text-white font-semibold rounded-2xl shadow-lg shadow-primary/20 hover:shadow-primary/30 transition-all text-center"
            >
              Comenzar Gratis Ahora
            </a>
            <a
              href="/login"
              class="w-full sm:w-auto px-8 py-4 bg-[#151D30] hover:bg-[#1E2942] text-gray-300 border border-[#1F293D] hover:text-white font-semibold rounded-2xl transition-all text-center"
            >
              Iniciar Sesión
            </a>
          </>
        )}
      </div>

      <!-- Feature Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-20 max-w-4xl mx-auto">
        <div class="p-6 rounded-2xl border border-[#1F293D] bg-[#151D30]/40 backdrop-blur-sm text-left">
          <div class="w-10 h-10 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center text-primary-light mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Graba y Sube</h3>
          <p class="text-gray-400 text-sm">Captura audio en vivo directo con tu micrófono o sube archivos MP3, WAV, WEBM de forma instantánea.</p>
        </div>

        <div class="p-6 rounded-2xl border border-[#1F293D] bg-[#151D30]/40 backdrop-blur-sm text-left">
          <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent-light mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 11.37 7.31 16.5 3 19" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Traducción Integrada</h3>
          <p class="text-gray-400 text-sm">Traduce tu transcripción original a múltiples idiomas usando modelos avanzados de OpenRouter y Google.</p>
        </div>

        <div class="p-6 rounded-2xl border border-[#1F293D] bg-[#151D30]/40 backdrop-blur-sm text-left">
          <div class="w-10 h-10 rounded-xl bg-green-500/10 border border-green-500/20 flex items-center justify-center text-green-400 mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Costos a Cero</h3>
          <p class="text-gray-400 text-sm">Conecta las capas de uso gratuito oficial de Google AI Studio, NVIDIA y OpenRouter para no pagar cargos adicionales.</p>
        </div>
      </div>
    </div>
  </div>
</Layout>
