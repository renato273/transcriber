---
import Layout from '../../layouts/Layout.astro';
import UsersAdminContent from '../../components/UsersAdminContent';

const user = Astro.locals.user;
if (!user || user.role !== 'ADMIN') {
  return Astro.redirect('/dashboard');
}
---

<Layout title="Administración de Usuarios">
  <div class="relative min-h-[calc(100vh-4rem)] flex flex-col bg-[#0B0F19]">
    <div class="absolute top-10 left-10 w-[200px] h-[200px] bg-accent/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-10 right-10 w-[200px] h-[200px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

    <UsersAdminContent client:load currentUserId={user.id} />
  </div>
</Layout>
