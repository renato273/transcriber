---
import Layout from '../layouts/Layout.astro';
import { isRegistrationOpen } from '../lib/registration';

const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/dashboard');
}

let registration = { open: true, needsBootstrap: true };
try {
  registration = await isRegistrationOpen();
} catch {
  registration = { open: false, needsBootstrap: false };
}
---

<Layout title="Registrarse">
  <div class="flex-grow flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] bg-accent/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-md w-full space-y-8 bg-[#151D30]/60 backdrop-blur-md border border-[#1F293D] p-5 sm:p-10 rounded-2xl sm:rounded-3xl z-10 relative">
      <div>
        <h2 class="text-center text-2xl sm:text-3xl font-extrabold text-white">
          {registration.needsBootstrap ? 'Crear administrador' : 'Crear una Cuenta'}
        </h2>
        <p class="mt-2 text-center text-sm text-gray-400">
          ¿Ya tienes cuenta?
          <a href="/login" class="font-medium text-primary hover:text-primary-light transition-colors">
            Inicia sesión aquí
          </a>
        </p>
      </div>

      {!registration.open ? (
        <div class="space-y-4 text-center">
          <div class="p-4 rounded-xl bg-amber-950/40 border border-amber-900/30 text-amber-200 text-sm leading-relaxed">
            El registro de nuevos usuarios está cerrado. Pedile a un administrador que habilite
            <span class="font-semibold"> “Permitir registro de nuevos usuarios”</span> en Administración.
          </div>
          <a
            href="/login"
            class="inline-flex min-h-[44px] items-center justify-center px-6 py-3 rounded-xl text-sm font-semibold text-white bg-primary hover:bg-primary-dark transition-all"
          >
            Ir a iniciar sesión
          </a>
        </div>
      ) : (
        <form id="registerForm" class="mt-8 space-y-6">
          {registration.needsBootstrap && (
            <div class="p-3 rounded-xl bg-primary/10 border border-primary/25 text-primary-light text-xs leading-relaxed">
              Este será el primer usuario del sistema y quedará como <strong>ADMIN</strong>. Después el registro público se cerrará automáticamente.
            </div>
          )}

          <div id="errorAlert" class="hidden p-4 rounded-xl bg-red-950/40 border border-red-900/30 text-red-400 text-sm"></div>
          <div id="successAlert" class="hidden p-4 rounded-xl bg-green-950/40 border border-green-900/30 text-green-400 text-sm"></div>

          <div class="rounded-md shadow-sm space-y-4">
            <div>
              <label for="email" class="block text-sm font-medium text-gray-300 mb-1.5">Correo Electrónico</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="appearance-none rounded-xl relative block w-full px-4 py-3 border border-[#1F293D] bg-[#0E1524] text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all sm:text-sm"
                placeholder="tu@correo.com"
              />
            </div>
            <div>
              <label for="password" class="block text-sm font-medium text-gray-300 mb-1.5">Contraseña</label>
              <input
                id="password"
                name="password"
                type="password"
                required
                class="appearance-none rounded-xl relative block w-full px-4 py-3 border border-[#1F293D] bg-[#0E1524] text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all sm:text-sm"
                placeholder="8+ caracteres, mayúscula, minúscula y especial"
              />
              <ul id="passwordRules" class="mt-2 space-y-1.5 text-xs text-gray-500">
                <li data-rule="minLength" class="flex items-center gap-2">○ Al menos 8 caracteres</li>
                <li data-rule="uppercase" class="flex items-center gap-2">○ Al menos 1 mayúscula (A-Z)</li>
                <li data-rule="lowercase" class="flex items-center gap-2">○ Al menos 1 minúscula (a-z)</li>
                <li data-rule="special" class="flex items-center gap-2">○ Al menos 1 carácter especial (!@#$...)</li>
              </ul>
            </div>
          </div>

          <div>
            <button
              type="submit"
              id="submitBtn"
              class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-semibold rounded-xl text-white bg-gradient-to-r from-accent to-accent-dark hover:from-accent-dark hover:to-accent focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-[#0B0F19] focus:ring-accent transition-all shadow-lg shadow-accent/10 hover:shadow-accent/20"
            >
              {registration.needsBootstrap ? 'Crear administrador' : 'Registrarse'}
            </button>
          </div>
        </form>
      )}
    </div>
  </div>

  {registration.open && (
    <script>
      const form = document.getElementById('registerForm') as HTMLFormElement;
      const errorAlert = document.getElementById('errorAlert') as HTMLDivElement;
      const successAlert = document.getElementById('successAlert') as HTMLDivElement;
      const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
      const passwordInput = document.getElementById('password') as HTMLInputElement;
      const defaultSubmitLabel = submitBtn?.innerText || 'Registrarse';

      function getPasswordChecks(password: string) {
        return {
          minLength: password.length >= 8,
          uppercase: /[A-Z]/.test(password),
          lowercase: /[a-z]/.test(password),
          special: /[^A-Za-z0-9]/.test(password),
        };
      }

      function isPasswordValid(password: string) {
        return Object.values(getPasswordChecks(password)).every(Boolean);
      }

      function updatePasswordRules() {
        const checks = getPasswordChecks(passwordInput?.value || '');
        document.querySelectorAll('#passwordRules [data-rule]').forEach((el) => {
          const rule = (el as HTMLElement).dataset.rule as keyof typeof checks;
          const ok = checks[rule];
          el.classList.toggle('text-green-400', ok);
          el.classList.toggle('text-gray-500', !ok);
          const label = el.textContent?.replace(/^[○●]\s*/, '') || '';
          el.textContent = `${ok ? '●' : '○'} ${label}`;
        });
      }

      passwordInput?.addEventListener('input', updatePasswordRules);
      updatePasswordRules();

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        errorAlert.classList.add('hidden');
        successAlert.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.innerText = 'Creando cuenta...';

        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = passwordInput.value;

        if (!isPasswordValid(password)) {
          const msg = 'La contraseña debe tener 8+ caracteres, 1 mayúscula, 1 minúscula y 1 carácter especial';
          errorAlert.innerText = msg;
          errorAlert.classList.remove('hidden');
          window.alerts?.toast.warning(msg);
          submitBtn.disabled = false;
          submitBtn.innerText = defaultSubmitLabel;
          return;
        }

        try {
          const response = await fetch('/api/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password }),
          });

          const data = await response.json();

          if (response.ok && data.success) {
            const msg = data.message || 'Cuenta creada con éxito. Redirigiendo a inicio de sesión...';
            successAlert.innerText = msg;
            successAlert.classList.remove('hidden');
            window.alerts?.toast.success(data.registrationClosed ? 'Admin creado · registro cerrado' : 'Cuenta creada con éxito');
            setTimeout(() => {
              window.location.href = '/login';
            }, 2000);
          } else {
            const msg = data.error || 'Ocurrió un error inesperado';
            errorAlert.innerText = msg;
            errorAlert.classList.remove('hidden');
            window.alerts?.toast.error(msg);
            submitBtn.disabled = false;
            submitBtn.innerText = defaultSubmitLabel;
          }
        } catch (err) {
          const msg = 'Error al conectar con el servidor';
          errorAlert.innerText = msg;
          errorAlert.classList.remove('hidden');
          window.alerts?.toast.error(msg);
          submitBtn.disabled = false;
          submitBtn.innerText = defaultSubmitLabel;
        }
      });
    </script>
  )}
</Layout>
