# Copiá este archivo a `.env` en la raíz del monorepo.
# NO subas el `.env` real a Git.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/transcriber"
JWT_SECRET="cambia-este-secreto-largo"
ENCRYPTION_KEY="cambia-esta-clave-de-cifrado"

# Cookies: false en HTTP/LAN; true solo si servís HTTPS
COOKIE_SECURE=false

# Local
AUDIO_STORAGE_PATH="./storage/audio"

# Producción / Docker
# HOST=0.0.0.0
# PORT=4321
# NODE_ENV=production
# AUDIO_STORAGE_PATH="/app/storage/audio"
# COOKIE_SECURE=true
